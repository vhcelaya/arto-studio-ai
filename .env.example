# Anthropic API Key (required for AI-powered roasts, falls back to deterministic if missing)
ANTHROPIC_API_KEY=

# Claude model to use (optional, defaults to claude-sonnet-4-20250514)
ANTHROPIC_MODEL=

# Neon Postgres connection string (optional — traces go to console.log if missing)
# Get one free at https://neon.tech — add as Vercel integration for auto-provisioning
DATABASE_URL=
