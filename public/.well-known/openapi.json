{
  "openapi": "3.1.0",
  "info": {
    "title": "ARTO Brand Roast API",
    "description": "Evaluate any brand using ARTO Studio AI's proprietary methodology. Returns scores across Strategy, Creativity, Narrative, and Digital pillars with detailed roasts and actionable improvements.",
    "version": "1.0.0",
    "contact": {
      "name": "ARTO Studio AI",
      "email": "vhcelaya@artogroup.com"
    }
  },
  "servers": [
    {
      "url": "https://arto-studio-ai.vercel.app",
      "description": "Production"
    }
  ],
  "paths": {
    "/api/roast": {
      "post": {
        "operationId": "roastBrand",
        "summary": "Roast a brand",
        "description": "Submit brand details and receive a brutally honest evaluation scored across 4 pillars using ARTO's methodology built from 15+ years of real brand strategy work.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RoastRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Brand roast result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RoastResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "string" },
                    "field": { "type": "string" }
                  }
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "string" },
                    "retryAfter": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/traces": {
      "get": {
        "operationId": "getTraces",
        "summary": "Query roast traces",
        "description": "Retrieve past roast traces with optional filtering. Use view=stats for aggregate statistics.",
        "parameters": [
          {
            "name": "view",
            "in": "query",
            "description": "Set to 'stats' for aggregate statistics instead of individual traces",
            "schema": { "type": "string", "enum": ["stats"] }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Max traces to return (default 50, max 100)",
            "schema": { "type": "integer", "default": 50, "maximum": 100 }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Offset for pagination",
            "schema": { "type": "integer", "default": 0 }
          },
          {
            "name": "industry",
            "in": "query",
            "description": "Filter by industry",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Traces or stats",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    { "$ref": "#/components/schemas/TracesListResponse" },
                    { "$ref": "#/components/schemas/TraceStatsResponse" }
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RoastRequest": {
        "type": "object",
        "required": ["brandName", "industry"],
        "properties": {
          "brandName": {
            "type": "string",
            "maxLength": 100,
            "description": "The brand name to evaluate"
          },
          "industry": {
            "type": "string",
            "description": "The brand's industry/sector",
            "enum": [
              "SaaS / B2B Software", "Consumer Tech", "Fintech", "Healthtech",
              "Edtech", "Proptech", "AI / Data", "E-commerce", "Fashion & Beauty",
              "Food & Beverage", "CPG", "Luxury", "Agency", "Professional Services",
              "Legal", "Finance", "Real Estate", "Education", "Health & Wellness",
              "Travel & Hospitality", "Manufacturing", "Automotive", "Energy",
              "Construction", "Logistics", "Entertainment", "Sports & Fitness",
              "Arts & Culture", "NGO / Social Impact", "Other"
            ]
          },
          "websiteUrl": {
            "type": "string",
            "format": "uri",
            "maxLength": 200,
            "description": "Brand's website URL (improves accuracy)"
          },
          "companySize": {
            "type": "string",
            "enum": ["solo", "micro", "small", "medium", "large", "enterprise"],
            "description": "Company size tier"
          },
          "description": {
            "type": "string",
            "maxLength": 500,
            "description": "What the brand does, its audience, and differentiators"
          }
        }
      },
      "PillarScore": {
        "type": "object",
        "properties": {
          "score": {
            "type": "number",
            "minimum": 1,
            "maximum": 10,
            "description": "Score from 1 to 10"
          },
          "roast": {
            "type": "string",
            "description": "2-3 sentence evaluation of this pillar"
          }
        }
      },
      "RoastResult": {
        "type": "object",
        "properties": {
          "overall": {
            "type": "number",
            "description": "Weighted overall score: Strategy(30%) + Creativity(25%) + Narrative(25%) + Digital(20%)"
          },
          "strategy": { "$ref": "#/components/schemas/PillarScore" },
          "creativity": { "$ref": "#/components/schemas/PillarScore" },
          "narrative": { "$ref": "#/components/schemas/PillarScore" },
          "digital": { "$ref": "#/components/schemas/PillarScore" },
          "verdict": {
            "type": "string",
            "description": "2-3 sentence overall verdict"
          },
          "improvements": {
            "type": "array",
            "items": { "type": "string" },
            "description": "3-5 specific, actionable improvements ranked by impact"
          }
        }
      },
      "RoastResponse": {
        "type": "object",
        "properties": {
          "source": {
            "type": "string",
            "enum": ["ai", "fallback"],
            "description": "'ai' when powered by Claude, 'fallback' when using deterministic scoring"
          },
          "result": { "$ref": "#/components/schemas/RoastResult" }
        }
      },
      "TracesListResponse": {
        "type": "object",
        "properties": {
          "traces": {
            "type": "array",
            "items": { "type": "object" }
          },
          "count": { "type": "integer" }
        }
      },
      "TraceStatsResponse": {
        "type": "object",
        "properties": {
          "total": { "type": "integer" },
          "avgOverall": { "type": "number" },
          "bySource": {
            "type": "object",
            "properties": {
              "ai": { "type": "integer" },
              "fallback": { "type": "integer" }
            }
          },
          "byIndustry": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "industry": { "type": "string" },
                "count": { "type": "integer" },
                "avgScore": { "type": "number" }
              }
            }
          }
        }
      }
    }
  }
}
